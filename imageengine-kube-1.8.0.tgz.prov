Hash: SHA512

annotations:
  artifacthub.io/changes: |
    - kind: changed
      description: "OSC sharding clients (backend, origin fetcher, processor) now discover the Object Storage Cache shards from the OSC headless Service's SRV record (OSCCLIENT_SRV_NAME) instead of the hand-maintained OSCCLIENT_ENVCONFIG + OSC{N}_HOST enumeration. The shard set now tracks objectStorageCache.replicaCount automatically — scaling OSC no longer requires editing a per-shard host list (ADR 0019)."
    - kind: added
      description: "OSC sharding clients route with rendezvous (HRW) hashing by default in Kubernetes (objectStorageCache.client.hash=hrw), so adding, removing, or rescheduling an OSC shard remaps only ~1/N of the keyspace and failover follows a stable preference list. Set objectStorageCache.client.hash=jump to keep Jump Consistent Hash (ADR 0020)."
  artifacthub.io/signKey: |
    fingerprint: C3A55111ED91FEDE4A82A4B4463266060957C4B3
