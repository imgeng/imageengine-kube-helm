Hash: SHA512

annotations:
  artifacthub.io/changes: |
    - kind: added
      description: "Split-topology installs: frontend.enabled and backendStack.enabled gate the frontend tier (edge+varnish) and the backend stack (backend, fetcher, processor, OSC) independently, so the pipeline can be deployed as separate frontend-only and backend-only releases (e.g. regional frontend PoPs pointing at a central backend). The full single-cluster pipeline remains the default (ADR 0021)."
    - kind: added
      description: "backend.service exposure block (type/port/annotations/loadBalancerSourceRanges/externalTrafficPolicy) lets a backend-only install publish the backend behind a LoadBalancer. Defaults to ClusterIP; a backend LoadBalancer must be private or source-range restricted (its listener carries unauthenticated admin endpoints and Varnish speaks plain HTTP) — see docs/TOPOLOGIES.md (ADR 0021)."
    - kind: removed
      description: "Removed the unused objectStorageCache.enabled value (no template referenced it)."
  artifacthub.io/signKey: |
    fingerprint: C3A55111ED91FEDE4A82A4B4463266060957C4B3
